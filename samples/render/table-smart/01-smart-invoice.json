        { "cells": ["Custom integration", "3", "$400.00", "$1,200.00"], "type": "normal", "pointed": false }
      ]
    },
    { "type": "spacer", "height": 12 },
    { "type": "paragraph", "text": "Total due: $4,350.00 — net 30." }
  ],
